APP_NAME=Tessa
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tessa.innovfix.ai

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=tessa_revenue
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Meta Ads
META_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=

# Slack Bot
SLACK_BOT_USER_OAUTH_TOKEN=

# ─── Remote MCP connector (Claude.ai custom connector) ──────────
# Master kill switch. When false the /.well-known endpoints, /oauth/*
# routes, and /mcp transport all 404 (the local stdio server in
# tessa-mcp-server/ keeps working). Flip to true once you've run the
# 2026_06_06_223000_* migrations and dogfooded internally.
MCP_REMOTE_ENABLED=false

# Public URLs used in the .well-known metadata documents. The resource
# URL is also baked into every issued token's audience (RFC 8707), so
# changing it invalidates existing tokens. Both default to APP_URL.
# MCP_RESOURCE_URL=https://tessa.innovfix.ai/mcp

# Token TTLs (seconds). Defaults: 30d access, 180d refresh.
# MCP_ACCESS_TOKEN_TTL=2592000
# MCP_REFRESH_TOKEN_TTL=15552000

# Comma-separated allowed Origin header values for /mcp.
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://claude.com

# Per-user calls per minute on /mcp.
# MCP_RATE_LIMIT=240

# Deeplink for the "Add to Claude" button on /settings/connect-claude.
# MCP_CLAUDE_CONNECT_URL=https://claude.ai/settings/connectors

# ── Google service account (Features 5 & 6: HR Sheet sync + Drive doc upload) ──
# DORMANT until you: (1) create a service account + JSON key in Google Cloud,
# (2) enable the Sheets API + Drive API, (3) share the master Sheet + Drive folder
# (Editor) with the service account's client_email, (4) drop the key at the path
# below and `chown www-data:www-data`. Sheet/folder IDs default to the program's
# targets in config/services.php, so usually only the key path + share emails are set.
# GOOGLE_SERVICE_ACCOUNT_JSON=/var/www/Tessa/storage/app/google/service-account.json
# GOOGLE_HR_SHEET_ID=1aAyyJe_SsHs88pqJLYF6K1AIRy4FScovtXyXASN-A4U
# GOOGLE_HR_SHEET_TAB=Sheet1
# GOOGLE_HR_DRIVE_FOLDER_ID=1NLGmXCNZwPB2-Mt-OY9PSGLTzvcs75H2
# Comma-separated HR emails the per-candidate Drive folder is shared with (read-only).
# GOOGLE_HR_SHARE_EMAILS=meghana@innovfix.in,akshara@innovfix.in

# ── Travel-Expense ledger sync (Travel Allowance trips → Drive + Google Sheet) ──
# NO service account — writes through a connected admin's "Connect Google" OAuth
# token (the WRITER): Shoyab #32 primary, Ayush #4 fallback. The ledger Sheet +
# screenshot folders live in that account's OWN Drive. Activates the moment the
# writer Disconnects + Connects Google to grant the drive + spreadsheets scopes
# (already in GOOGLE_SCOPES); until then trips just log locally. The root folder
# ("Travel Expenses/") + master ledger Sheet are AUTO-CREATED — nothing to provision.
# GOOGLE_TRAVEL_WRITER_IDS=32,4
# Emails the root folder + ledger Sheet are shared with (reader) so the other
# accountant can open them even though they live in the writer's Drive.
# TRAVEL_SHARE_EMAILS=ayush@innovfix.in,shoyab@innovfix.in
# Optional overrides (default empty ⇒ find-or-create by name):
# TRAVEL_DRIVE_ROOT_NAME=Travel Expenses
# TRAVEL_LEDGER_SHEET_NAME=Travel Expenses — Master Ledger
# TRAVEL_DRIVE_FOLDER_ID=          # pin an existing root folder by id
# TRAVEL_LEDGER_SHEET_ID=          # pin an existing ledger Sheet by id
